  "keyFeatures": [
    "Zoom any HTML element with mouse wheel, pinch, or programmatic API",
    "Drag to pan the zoomed element with mouse or touch",
    "Mobile-first pinch-to-zoom gesture support",
    "Built-in Slider module for zoom level control",
    "Built-in Zoomer module with in/out/reset buttons",
    "Smooth drag animation with configurable damping",
    "Boundary constraints to keep content in view",
    "Rich event system for all interaction states",
    "TypeScript-first with full type definitions",
    "Zero dependencies, CDN-ready UMD and ES module builds"
  ],
  "publicApiSurface": [
